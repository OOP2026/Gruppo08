<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="gui.LoginPage">
  <grid id="27dc6" binding="basePanel" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties>
      <background color="-13553359"/>
      <foreground color="-13553359"/>
    </properties>
    <border type="none"/>
    <children>
      <grid id="f0bc5" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints border-constraint="North"/>
        <properties>
          <background color="-13553359"/>
          <foreground color="-13553359"/>
        </properties>
        <border type="none"/>
        <children>
          <component id="73b0" class="javax.swing.JLabel" binding="logLabel" custom-create="true">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font size="14" style="1"/>
              <foreground color="-2894893"/>
              <text value="Servizio Università"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="409cf" binding="inputsPanel" layout-manager="FormLayout">
        <rowspec value="center:d:grow"/>
        <rowspec value="top:4dlu:noGrow"/>
        <rowspec value="center:max(d;4px):noGrow"/>
        <rowspec value="top:4dlu:noGrow"/>
        <rowspec value="center:max(d;4px):noGrow"/>
        <rowspec value="top:4dlu:noGrow"/>
        <rowspec value="center:max(d;4px):noGrow"/>
        <rowspec value="top:4dlu:noGrow"/>
        <rowspec value="center:max(d;4px):noGrow"/>
        <rowspec value="top:4dlu:noGrow"/>
        <rowspec value="center:max(d;4px):noGrow"/>
        <rowspec value="top:4dlu:noGrow"/>
        <rowspec value="center:max(d;4px):noGrow"/>
        <rowspec value="top:4dlu:noGrow"/>
        <rowspec value="center:d:grow"/>
        <colspec value="fill:d:grow"/>
        <colspec value="left:4dlu:noGrow"/>
        <colspec value="fill:d:grow"/>
        <colspec value="left:4dlu:noGrow"/>
        <colspec value="fill:d:grow"/>
        <constraints border-constraint="Center"/>
        <properties>
          <background color="-13553359"/>
          <foreground color="-13553359"/>
        </properties>
        <border type="none"/>
        <children>
          <component id="b9df3" class="javax.swing.JLabel">
            <constraints>
              <grid row="2" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
              <forms defaultalign-horz="false"/>
            </constraints>
            <properties>
              <foreground color="-2894893"/>
              <text value="Ruolo:"/>
            </properties>
          </component>
          <component id="7af79" class="javax.swing.JComboBox" binding="roleComboBox">
            <constraints>
              <grid row="4" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="2" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
              <forms/>
            </constraints>
            <properties>
              <model>
                <item value="Studente"/>
                <item value="Docente"/>
                <item value="Coordinatore"/>
              </model>
            </properties>
          </component>
          <component id="f1b03" class="javax.swing.JLabel">
            <constraints>
              <grid row="6" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
              <forms defaultalign-horz="false"/>
            </constraints>
            <properties>
              <foreground color="-2894893"/>
              <text value="Email/Username:"/>
            </properties>
          </component>
          <component id="412c4" class="javax.swing.JTextField" binding="loginTextField">
            <constraints>
              <grid row="8" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="150" height="-1"/>
              </grid>
              <forms defaultalign-horz="false"/>
            </constraints>
            <properties/>
          </component>
          <component id="21a03" class="javax.swing.JLabel">
            <constraints>
              <grid row="10" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
              <forms defaultalign-horz="false"/>
            </constraints>
            <properties>
              <foreground color="-2894893"/>
              <text value="Password:"/>
            </properties>
          </component>
          <hspacer id="f6260">
            <constraints>
              <grid row="8" column="4" row-span="1" col-span="1" vsize-policy="1" hsize-policy="6" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
              <forms defaultalign-horz="false"/>
            </constraints>
          </hspacer>
          <hspacer id="30e46">
            <constraints>
              <grid row="8" column="0" row-span="1" col-span="1" vsize-policy="1" hsize-policy="6" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
              <forms defaultalign-horz="false"/>
            </constraints>
          </hspacer>
          <vspacer id="a9107">
            <constraints>
              <grid row="0" column="2" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
              <forms defaultalign-vert="false"/>
            </constraints>
          </vspacer>
          <vspacer id="a3b74">
            <constraints>
              <grid row="14" column="2" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
              <forms defaultalign-vert="false"/>
            </constraints>
          </vspacer>
          <component id="62cac" class="javax.swing.JPasswordField" binding="pswdField">
            <constraints>
              <grid row="12" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="150" height="-1"/>
              </grid>
              <forms defaultalign-horz="false"/>
            </constraints>
            <properties/>
          </component>
        </children>
      </grid>
      <grid id="b19c9" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
        <constraints border-constraint="South"/>
        <properties>
          <background color="-13553359"/>
          <foreground color="-13553359"/>
        </properties>
        <border type="none"/>
        <children>
          <component id="f2b37" class="javax.swing.JButton" binding="loginButton" default-binding="true">
            <constraints/>
            <properties>
              <background color="-11579569"/>
              <foreground color="-2894893"/>
              <text value="Login"/>
            </properties>
          </component>
          <component id="487c3" class="javax.swing.JButton" binding="regButton">
            <constraints/>
            <properties>
              <background color="-11579569"/>
              <foreground color="-2894893"/>
              <text value="Registra"/>
            </properties>
          </component>
        </children>
      </grid>
    </children>
  </grid>
</form>
