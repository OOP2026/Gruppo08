<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="gui.ReqPage">
  <grid id="27dc6" binding="basePanel" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties>
      <background color="-13553359"/>
      <foreground color="-13553359"/>
    </properties>
    <border type="none"/>
    <children>
      <grid id="df611" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints border-constraint="North"/>
        <properties>
          <background color="-13553359"/>
          <foreground color="-13553359"/>
        </properties>
        <border type="none"/>
        <children>
          <component id="db2b5" class="javax.swing.JLabel">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <background color="-13553359"/>
              <font size="20" style="1"/>
              <foreground color="-2894893"/>
              <text value="Richiedi spostamento"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="c8d9" layout-manager="GridLayoutManager" row-count="1" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints border-constraint="South"/>
        <properties>
          <background color="-13553359"/>
          <foreground color="-13553359"/>
        </properties>
        <border type="none"/>
        <children>
          <component id="92875" class="javax.swing.JButton" binding="confermaButton" default-binding="true">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <background color="-13925350"/>
              <foreground color="-2894893"/>
              <text value="Conferma"/>
            </properties>
          </component>
          <component id="32e81" class="javax.swing.JButton" binding="indietroButton">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <background color="-11579569"/>
              <enabled value="true"/>
              <foreground color="-2894893"/>
              <text value="Indietro"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="1d9b9" layout-manager="FormLayout">
        <rowspec value="center:d:noGrow"/>
        <rowspec value="top:4dlu:noGrow"/>
        <rowspec value="center:max(d;4px):noGrow"/>
        <rowspec value="top:4dlu:noGrow"/>
        <rowspec value="center:max(d;4px):noGrow"/>
        <rowspec value="top:4dlu:noGrow"/>
